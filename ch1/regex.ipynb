   "metadata": {},
   "outputs": [],
   "source": [
    "# 주민등록번호 => 뒷자리를 모두 * 문자로 변경\n",
    "\n",
    "#파이썬에서 정규식 지원하는 모듈\n",
    "# ---익선돈까스\n",
    "import re\n",
    "\n",
    "dir(re)\n",
    "\n",
    "#re.compile() : 정규식을 작성\n",
    "\n",
    "pattern = re.compile(\"ab*\")\n",
